{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "build/web",
  "routes": [
    {
      "src": "/api/aula/(.*)",
      "dest": "https://didarsis.com/api/aula/$1"
    },
    {
      "src": "/numera/(.*)",
      "dest": "/$1"
    },
    {
      "src": "^/$",
      "status": 308,
      "headers": { "Location": "/numera/" }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
